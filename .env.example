# =============================================================================
# HederaAgentContent - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your API keys.
# Never commit the .env file to version control.
# =============================================================================

# --- LLM Provider -----------------------------------------------------------
OPENAI_API_KEY=               # Required: OpenAI API key for GPT models
OPENAI_MODEL=gpt-4o-mini     # Optional: default model (gpt-4o-mini, gpt-4o, gpt-5.1)

# --- YouTube Data API v3 ----------------------------------------------------
YOUTUBE_API_KEY=              # Required: Google Cloud YouTube Data API v3 key
HEDERA_YOUTUBE_CHANNEL_ID=UCIhE4NYpaX9E6SZQFq6JE  # Hedera official channel

# --- X / Twitter API v2 -----------------------------------------------------
TWITTER_API_KEY=              # Required: Twitter API key (consumer key)
TWITTER_API_SECRET=           # Required: Twitter API secret (consumer secret)
TWITTER_ACCESS_TOKEN=         # Required: Twitter access token
TWITTER_ACCESS_SECRET=        # Required: Twitter access token secret
TWITTER_BEARER_TOKEN=         # Required: Twitter bearer token (for search)

# --- Medium API --------------------------------------------------------------
MEDIUM_TOKEN=                 # Required: Medium integration token
                              # Get it at: https://medium.com/me/settings/security

# --- Discord Webhook ---------------------------------------------------------
DISCORD_WEBHOOK_URL=          # Required: Discord channel webhook URL
                              # Server Settings > Integrations > Webhooks > New Webhook

# --- Optional: Web Search (Serper) -------------------------------------------
SERPER_API_KEY=               # Optional: SerpAPI/Serper key for web search fallback
